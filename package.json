    "e2e": "playwright test",
    "verify": "npm run typecheck && npm run build && npm run audit"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.8",
    "@zxing/browser": "0.2.1",
    "@zxing/library": "0.23.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "esbuild": "^0.28.1",
    "typescript": "5.9.3",
    "vite": "^7.3.6"
  }
}
